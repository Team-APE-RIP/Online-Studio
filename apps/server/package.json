{
  "name": "@team-ape-rip/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run build --workspace @team-ape-rip/shared && nest build",
    "with:db-env": "node --env-file=../../.env scripts/with-db-env.mjs",
    "start": "npm run with:db-env -- node dist/apps/server/src/main.js",
    "start:dev": "npm run build --workspace @team-ape-rip/shared && npm run build && npm run with:db-env -- node dist/apps/server/src/main.js",
    "start:prod": "npm run with:db-env -- node dist/apps/server/src/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "npm run with:db-env -- prisma migrate deploy",
    "prisma:migrate:dev": "npm run with:db-env -- prisma migrate dev",
    "prisma:push": "npm run with:db-env -- prisma db push",
    "prisma:seed": "npm run with:db-env -- ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.11",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/websockets": "^11.1.17",
    "@prisma/client": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.1",
    "@nestjs/testing": "^11.0.11",
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}