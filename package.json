{
  "name": "team-ape-rip-online-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Team-APE-RIP-Online-Studio monorepo for HOI4 modding collaboration platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @team-ape-rip/web",
    "dev:server": "npm run start:dev --workspace @team-ape-rip/server",
    "build:web": "npm run build --workspace @team-ape-rip/web",
    "build:server": "npm run build --workspace @team-ape-rip/server",
    "build": "npm run build:web && npm run build:server",
    "start:web": "npm run start --workspace @team-ape-rip/web",
    "start:server": "npm run start:prod --workspace @team-ape-rip/server"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}